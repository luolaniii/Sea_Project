# ==============================================
# 通用缓存
# ==============================================
.DS_Store
Thumbs.db
*.swp
*.tmp
*.log
.qoder/

# IDE配置
.idea/
.vscode/
*.iml
*.iws
*.ipr

# ==============================================
# 前端 front 强制忽略（核心！）
# ==============================================
# 忽略front下所有node_modules（无论层级）
front/node_modules/
front/**/node_modules/

# 忽略front下所有打包文件夹
front/dist/
front/build/
front/output/

# 忽略前端环境变量、日志
front/.env*
front/npm-debug.log*
front/yarn-debug.log*

# ==============================================
# 后端 springboot-demo 忽略
# ==============================================
springboot-demo/target/
springboot-demo/*.class
springboot-demo/.mvn/
springboot-demo/mvnw
springboot-demo/mvnw.cmd
springboot-demo/application-dev.yml

# ==============================================
# 你的要求：忽略所有md文件
# ==============================================
*.md

# ==============================================
# 其他压缩包/可执行文件
# ==============================================
*.zip
*.rar
*.exe

# ==============================================
# 不上传数据源/描述文档
# ==============================================
*.txt
*.pdf
*.doc
*.docx